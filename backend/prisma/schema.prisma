generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            Int       @id
  created_at    DateTime? @db.Timestamptz(6)
  name          String?
  price         Decimal?  @db.Decimal
  image         String?
  stock         Int?
  description   String?
  weight        String?
  grade         String?
  originalPrice Decimal?  @db.Decimal
  badge         String?
  rating        Decimal?  @db.Decimal
  reviews       Int?
  features      Json?
  status        String?
  updated_at    DateTime? @db.Timestamptz(6)
  sku           String?

  @@map("product")
}

model Address {
  id         String    @id @db.Uuid
  street     String?   @db.VarChar
  city       String?   @db.VarChar
  state      String?   @db.VarChar
  pincode    String?   @db.VarChar
  is_default Boolean?
  created_at DateTime? @db.Timestamptz(6)
  user_id    Int?

  @@map("address")
}

model Cart {
  id         String    @id @db.Uuid
  user_id    String?
  created_at DateTime? @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)

  @@map("cart")
}

model Order {
  id                  String    @id @db.Uuid
  status              String?   @db.VarChar
  total_amount        Decimal?  @db.Decimal
  created_at          DateTime? @db.Timestamptz(6)
  user_id             Int?
  billing_address     Json?
  shipping_address    Json?
  payment_method      String?   @db.VarChar
  payment_status      String?   @db.VarChar
  order_id            String?   @db.VarChar
  order_details       Json?
  cancellation_reason String?

  @@map("order")
}

model OrderItem {
  id           String    @id @db.Uuid
  order_id     String?   @db.Uuid
  product_id   Int?
  quantity     Int?
  price        Decimal?  @db.Decimal
  delivered    Boolean?
  created_at   DateTime? @db.Timestamptz(6)
  product_name String?
  image        String?
  grade        String?
  weight       String?

  @@map("orderitem")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model cart_items {
  id             String    @id @db.Uuid
  cart_id        String?   @db.Uuid
  product_id     Int?
  product_name   String?
  price          Decimal?  @db.Decimal
  quantity       Int?
  original_price Decimal?  @db.Decimal
  image          String?
  grade          String?
  weight         String?
  created_at     DateTime? @db.Timestamptz(6)
  updated_at     DateTime? @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model query {
  id         String    @id @db.Uuid
  name       String?   @db.VarChar
  email      String?   @db.VarChar
  phone      String?   @db.VarChar
  subject    String?   @db.VarChar
  message    String?
  status     String?   @db.VarChar
  created_at DateTime? @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)
}

model admin {
  admin_id   BigInt    @id
  email      String    @db.VarChar
  password   String    @db.VarChar
  created_at DateTime? @db.Timestamptz(6)
  updated_at DateTime? @db.Timestamptz(6)
}

model users {
  id        Int       @id(map: "user_pkey")
  name      String?
  email     String?   @unique
  password  String?
  role      String?
  createdAt DateTime? @db.Timestamp(6)
  updatedAt DateTime? @db.Timestamp(6)
  phone     String?   @db.VarChar
}
