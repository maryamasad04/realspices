# Option B: SMTP (e.g. Gmail with an App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-16-char-app-password
# EMAIL_FROM=Real Spices <your@gmail.com>

